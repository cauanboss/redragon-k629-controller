{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Redragon K629 Controller",
  "version": "1.0.0",
  "identifier": "com.redragon.k629-controller",
  "build": {
    "frontendDist": "../dist",
    "beforeDevCommand": "cd .. && pnpm build:backend && pnpm build:frontend",
    "beforeBuildCommand": "cd .. && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "Redragon K629 Controller",
        "width": 1080,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "minWidth": 800,
        "minHeight": 500
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "resources": {
      "../../bundle/backend": "backend"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
