{
  "name": "redragon-k629-controller",
  "version": "0.1.0",
  "description": "Software para controle do teclado Redragon K629CGO-PRO-M",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && cp src/web/index.html src/web/style.css dist/web/",
    "start": "node dist/index.js",
    "cli": "node dist/cli.js",
    "dev": "tsx src/start-server.ts",
    "dev:server": "tsx src/start-server.ts",
    "dev:cli": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "express": "^5.1.0",
    "node-hid": "^3.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/node-hid": "^3.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.8.0",
    "tsx": "^4.19.0",
    "vitest": "^3.1.0"
  }
}
